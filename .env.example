# =====================================================================
# Multhingverse – environment configuration template
# Copy this file to .env and fill in real values before running:
#   cp .env.example .env
# =====================================================================

# ─────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────
POSTGRES_USER=multhingverse
POSTGRES_PASSWORD=changeme_db_password
POSTGRES_DB=multhingverse_db

# ─────────────────────────────────────────
# Application secrets
# ─────────────────────────────────────────
# JWT signing secret – must be the same across all microservices
JWT_SECRET=changeme_jwt_secret_use_a_long_random_string

# ─────────────────────────────────────────
# Google OAuth2
# ─────────────────────────────────────────
# Get these from Google Cloud Console → APIs & Services → Credentials
# Authorised redirect URI to register: http://<your-host>/oauth2/callback
GOOGLE_CLIENT_ID=319224631795-bp9qr2cm49chnm2pqqpsbbb9j82oh5j6.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=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



# ─────────────────────────────────────────
# Nginx / network
# ─────────────────────────────────────────
# Host port to bind nginx on (default 80)
HTTP_PORT=80

# ─────────────────────────────────────────
# Notes
# ─────────────────────────────────────────
# All other service wiring (Kafka host, DB host, inter-service URLs)
# is derived automatically from Docker Compose service names and does
# not need to be set here.
#
# For cloud deployments: set POSTGRES_PASSWORD and JWT_SECRET via
# your cloud provider's secrets manager / environment injection and
# never commit the actual .env file to version control.
